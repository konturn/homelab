#include <tunables/global>

# AppArmor profile for Telegraf container D-Bus access.
# Allows read-only systemd unit queries (ListUnits, ListUnitFiles, GetUnit)
# needed by the systemd_units input plugin. Denies all other D-Bus operations
# (Start/Stop/Restart/Kill/Reload/etc.) to prevent the container from
# modifying host services.

profile telegraf-dbus-readonly flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>

  # Docker default profile capabilities — inherit standard container permissions
  #include <abstractions/nameservice>

  # Standard container filesystem access
  file,
  network,
  capability,
  mount,
  umount,
  pivot_root,
  signal,
  ptrace,

  # D-Bus: Allow connecting to the system bus
  dbus bus=system send
       interface=org.freedesktop.DBus
       member={Hello,AddMatch,GetNameOwner,GetId},

  dbus bus=system receive
       interface=org.freedesktop.DBus
       member={Hello,AddMatch,GetNameOwner,GetId,NameOwnerChanged,NameAcquired},

  # D-Bus: Allow read-only systemd queries
  dbus bus=system send
       interface=org.freedesktop.systemd1.Manager
       member={ListUnits,ListUnitFiles,GetUnit},

  dbus bus=system receive
       interface=org.freedesktop.systemd1.Manager
       member={ListUnits,ListUnitFiles,GetUnit},

  # D-Bus: Allow reading systemd unit properties
  dbus bus=system send
       interface=org.freedesktop.DBus.Properties
       member={Get,GetAll},

  dbus bus=system receive
       interface=org.freedesktop.DBus.Properties
       member={Get,GetAll,PropertiesChanged},

  # Deny all other D-Bus operations (implicit — AppArmor denies by default)
  # This explicitly blocks: StartUnit, StopUnit, RestartUnit, KillUnit,
  # ReloadUnit, ResetFailedUnit, EnableUnitFiles, DisableUnitFiles, etc.

  # Deny ptrace for extra hardening (not needed by telegraf)
  deny ptrace (read, readby),
}
